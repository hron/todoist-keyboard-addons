{
  "manifest_version": 3,
  "name": "Todoist Keyboard Add-ons",
  "version": "1.1",
  "description": "Extra keyboard shortcuts for Todoist",
  "permissions": ["storage"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["*://app.todoist.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
